{
    "$defs": {
        "type-sys": {
            "properties": {
                "type": {
                    "const": "sys"
                }
            }
        },
        "type-req": {
            "properties": {
                "type": {
                    "const": "req"
                }
            }
        },
        "type-spec": {
            "properties": {
                "type": {
                    "const": "spec"
                }
            }
        },
        "type-test": {
            "properties": {
                "type": {
                    "const": "test"
                }
            }
        }
    },
    "schemas": [
        {
            "id": "sys-allowed-links",
            "severity": "violation",
            "message": "A system requirement may not use outgoing custom links.",
            "select": {
                "$ref": "#/$defs/type-sys"
            },
            "validate": {
                "local": {
                    "properties": {
                        "satisfies": {
                            "type": "array",
                            "maxItems": 0
                        },
                        "verifies": {
                            "type": "array",
                            "maxItems": 0
                        },
                        "implements": {
                            "type": "array",
                            "maxItems": 0
                        },
                        "tests": {
                            "type": "array",
                            "maxItems": 0
                        },
                        "covers": {
                            "type": "array",
                            "maxItems": 0
                        }
                    }
                }
            }
        },
        {
            "id": "req-allowed-links",
            "severity": "violation",
            "message": "A requirement may only link via 'satisfies' and 'verifies'.",
            "select": {
                "$ref": "#/$defs/type-req"
            },
            "validate": {
                "local": {
                    "properties": {
                        "implements": {
                            "type": "array",
                            "maxItems": 0
                        },
                        "tests": {
                            "type": "array",
                            "maxItems": 0
                        },
                        "covers": {
                            "type": "array",
                            "maxItems": 0
                        }
                    }
                }
            }
        },
        {
            "id": "req-must-satisfy",
            "severity": "violation",
            "message": "A 'req' must have at least one 'satisfies' link to a system requirement.",
            "select": {
                "$ref": "#/$defs/type-req"
            },
            "validate": {
                "local": {
                    "properties": {
                        "satisfies": {
                            "type": "array",
                            "minItems": 1
                        }
                    },
                    "required": [
                        "satisfies"
                    ]
                }
            }
        },
        {
            "id": "req-satisfies-must-not-target-test",
            "severity": "violation",
            "message": "A 'req' must not satisfy a test case. The 'satisfies' link must only target system requirements ('sys').",
            "select": {
                "$ref": "#/$defs/type-req"
            },
            "validate": {
                "network": {
                    "satisfies": {
                        "items": {
                            "local": {
                                "$ref": "#/$defs/type-sys"
                            }
                        }
                    }
                }
            }
        },
        {
            "id": "spec-allowed-links",
            "severity": "violation",
            "message": "A specification may only link via 'implements' and 'tests'.",
            "select": {
                "$ref": "#/$defs/type-spec"
            },
            "validate": {
                "local": {
                    "properties": {
                        "satisfies": {
                            "type": "array",
                            "maxItems": 0
                        },
                        "verifies": {
                            "type": "array",
                            "maxItems": 0
                        },
                        "covers": {
                            "type": "array",
                            "maxItems": 0
                        }
                    }
                }
            }
        },
        {
            "id": "test-allowed-links",
            "severity": "violation",
            "message": "A test case may only link via 'verifies'.",
            "select": {
                "$ref": "#/$defs/type-test"
            },
            "validate": {
                "local": {
                    "properties": {
                        "satisfies": {
                            "type": "array",
                            "maxItems": 0
                        },
                        "implements": {
                            "type": "array",
                            "maxItems": 0
                        },
                        "tests": {
                            "type": "array",
                            "maxItems": 0
                        },
                        "covers": {
                            "type": "array",
                            "maxItems": 0
                        }
                    }
                }
            }
        },
        {
            "id": "safety-level-enum",
            "severity": "violation",
            "message": "safety_level must be one of: QM, ASIL-A, ASIL-B, ASIL-C, ASIL-D.",
            "validate": {
                "local": {
                    "properties": {
                        "safety_level": {
                            "type": "string",
                            "enum": [
                                "QM",
                                "ASIL-A",
                                "ASIL-B",
                                "ASIL-C",
                                "ASIL-D"
                            ]
                        }
                    }
                }
            }
        }
    ]
}
